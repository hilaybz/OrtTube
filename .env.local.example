# Copy this file to `.env.local` and fill in real values for local development.

# ── Anthropic ──────────────────────────────────────────────────────────────
# Claude API key — required for quiz generation, translation, and the AI tutor.
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ────────────────────────────────────────────────────────────────
# Local dev uses the Supabase CLI stack (`supabase start`). The URL + anon/
# service-role keys are printed by `supabase start` / `supabase status`.
# Reuse NEXT_PUBLIC_SUPABASE_URL everywhere — do NOT introduce a second
# SUPABASE_URL var. The service-role key bypasses RLS and is server-only.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Supabase CLI local default). Used by the test
# harness to reset/seed and by any Node-side raw SQL.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Storage (transcript cache) ──────────────────────────────────────────────
# Supabase Storage bucket that holds cached YouTube transcripts (one JSON object
# per youtube_video_id). Defaults to `transcripts`.
TRANSCRIPT_BUCKET=transcripts

# ── Job / admin endpoint secrets ────────────────────────────────────────────
# Two SEPARATE secrets so a leaked cron secret cannot create teachers or delete
# users. `CRON_SECRET` guards scheduled jobs under /api/jobs/*; `ADMIN_SECRET`
# guards destructive admin endpoints (/api/admin/seed-teacher, /delete-user).
# Both are checked as `Authorization: Bearer <secret>`.
CRON_SECRET=generate-a-long-random-string
ADMIN_SECRET=generate-a-different-long-random-string
